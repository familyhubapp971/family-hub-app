{
  "name": "family-hub-app",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-tenant SaaS platform for families. Monorepo root.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "volta": {
    "node": "20.19.0",
    "pnpm": "10.32.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "dev:up": "docker compose up -d --wait",
    "dev:down": "docker compose down",
    "dev:reset": "docker compose down -v && docker compose up -d --wait",
    "seed": "./scripts/seed",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pretest:integration": "pnpm test:db:up",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:integration:watch": "vitest --config tests/integration/vitest.config.ts",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down",
    "_assert-bddgen": "find tests/e2e/.features-gen -name '*.spec.js' | grep -q . || (echo '✗ bddgen produced 0 specs — feature/step paths broken?' && exit 1)",
    "_assert-bddgen-critical": "find tests/e2e/.features-gen-critical -name '*.spec.js' | grep -q . || (echo '✗ bddgen produced 0 specs — feature/step paths broken or @critical tag missing?' && exit 1)",
    "test:e2e": "bddgen test --config tests/e2e/playwright.config.ts && pnpm run _assert-bddgen && playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:critical": "bddgen test --config tests/e2e/playwright.critical.config.ts && pnpm run _assert-bddgen-critical && playwright test --config tests/e2e/playwright.critical.config.ts",
    "test:e2e:ui": "bddgen test --config tests/e2e/playwright.config.ts && pnpm run _assert-bddgen && playwright test --ui --config tests/e2e/playwright.config.ts",
    "perf:smoke": "tests/performance/scripts/run-k6.sh tests/performance/scenarios/smoke.js",
    "perf:load": "tests/performance/scripts/run-k6.sh tests/performance/scenarios/load.js",
    "perf:stress": "tests/performance/scripts/run-k6.sh tests/performance/scenarios/stress.js",
    "perf:soak": "tests/performance/scripts/run-k6.sh tests/performance/scenarios/soak.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules/.cache",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@playwright/test": "1.48.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@types/node": "20.16.11",
    "@types/pg": "8.11.10",
    "@vitejs/plugin-react": "4.3.3",
    "@vitest/coverage-v8": "2.1.4",
    "drizzle-orm": "0.36.1",
    "eslint": "9.18.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.1.0",
    "globals": "15.14.0",
    "hono": "4.6.10",
    "husky": "9.1.7",
    "jose": "^5.10.0",
    "jsdom": "25.0.1",
    "lint-staged": "15.4.3",
    "pg": "8.13.1",
    "playwright-bdd": "8.4.2",
    "prettier": "3.4.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "5.6.3",
    "typescript-eslint": "8.18.2",
    "vitest": "2.1.4"
  },
  "packageManager": "pnpm@10.32.0"
}
