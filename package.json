{
  "name": "family-hub-app",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-tenant SaaS platform for families. Monorepo root.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "volta": {
    "node": "20.15.1",
    "pnpm": "10.32.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules/.cache"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "2.1.4",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  },
  "packageManager": "pnpm@10.32.0"
}
