#!/usr/bin/env bash
# ./scripts/dev — one-command local development.
#
# Spins up dev Postgres → applies Drizzle migrations → boots api + web
# in parallel via the existing root `pnpm dev` (`pnpm -r --parallel
# --stream dev`). Clean teardown on Ctrl-C: stops api/web, leaves the
# Postgres container running so the next `./scripts/dev` is instant.
# To stop the database too: `pnpm dev:down`.
#
# Requires: docker (Compose v2), pnpm, .env.local. If .env.local is
# missing it's created from .env.example as a courtesy.

set -euo pipefail

command -v docker >/dev/null || { echo "✗ docker not found on PATH" >&2; exit 1; }
command -v pnpm   >/dev/null || { echo "✗ pnpm not found on PATH"   >&2; exit 1; }

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

if [[ ! -f .env.local ]]; then
  echo "→ .env.local missing — copying from .env.example"
  cp .env.example .env.local
fi

echo "→ Starting dev Postgres (docker compose up -d --wait)..."
docker compose up -d --wait

echo "→ Applying Drizzle migrations (drizzle-kit push)..."
# Schema is intentionally empty until Sprint 1 (ADR 0001). Until then
# `db:push` is a no-op that confirms the connection. Once tenants/users
# land it'll apply schema changes idempotently.
pnpm --filter @familyhub/api db:push

echo "→ Booting api (:3001) + web (:5173) — Ctrl-C to stop..."
# exec so signal/exit semantics from `pnpm dev` pass through transparently
# (Ctrl-C reaches api + web; non-zero exits aren't reframed by the wrapper).
exec pnpm dev
