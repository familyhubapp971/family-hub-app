{
  "name": "@familyhub/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -c '([ -f ../../.env.local ] && tsx watch --env-file=../../.env.local src/index.ts) || tsx watch src/index.ts'",
    "start": "node node_modules/drizzle-kit/bin.cjs push --force && sh -c '([ -f ../../.env.local ] && node --env-file=../../.env.local dist/index.js) || node dist/index.js'",
    "build": "tsc --noEmit && node build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "node --env-file=../../.env.local node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=../../.env.local node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --env-file=../../.env.local node_modules/drizzle-kit/bin.cjs push",
    "db:seed": "tsx --env-file=../../.env.local src/db/seed.ts",
    "db:studio": "node --env-file=../../.env.local node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@familyhub/shared": "workspace:*",
    "@hono/node-server": "1.13.7",
    "@hono/zod-validator": "0.4.1",
    "@sentry/node": "^8.55.2",
    "drizzle-orm": "0.36.1",
    "hono": "4.6.10",
    "jose": "^5.10.0",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.16.11",
    "@types/pg": "8.11.10",
    "drizzle-kit": "0.28.0",
    "esbuild": "0.23.1",
    "pino-pretty": "^13.1.3",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
