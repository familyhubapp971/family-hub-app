# Copy to .env.local and fill in. .env.local is gitignored.
# Place at the REPO ROOT (not apps/api/). The api dev script loads it via
# --env-file=../../.env.local. In production (Railway) envs are injected
# by the platform — this file is dev-only.

# ─── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ─── Postgres ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://localhost:5432/familyhub_dev

# ─── Jira ↔ GitHub automation (used by scripts, not the API) ───────────────
# EMAIL=you@example.com
# JIRA_API_TOKEN=
# JIRA_URL=https://qualicion2.atlassian.net/

# ─── Supabase (FHS-178 epic — populated when Supabase is wired) ────────────
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (FHS-68 epic — populated when Stripe is wired) ─────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ─── Sentry (FHS-166 — populated when Sentry is wired) ─────────────────────
# SENTRY_DSN=
